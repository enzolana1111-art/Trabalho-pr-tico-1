<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BH Shopping Guide</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <header>
    <div class="header-container container">
      <div class="logo">BH Shopping Guide</div>
      <button class="menu-toggle" id="menuToggle">☰</button>
      <nav id="navMenu">
        <a href="index.html">Home</a>
        <a href="#masculino">Masculino</a>
        <a href="#feminino">Feminino</a>
      </nav>
    </div>
  </header>

  <main class="container py-4">

    <section class="text-center mb-5">
      <h1>Encontre suas lojas favoritas com facilidade!</h1>
      <p class="lead">Aqui você localiza as melhores marcas de moda na capital mineira.</p>
    </section>

    <!-- Cards Masculino -->
    <section id="masculino" class="mb-5">
      <h2 class="mb-1">Masculino</h2>
      <p class="text-muted mb-3">Lojas de moda masculina em Belo Horizonte.</p>
      <div id="lojas-masculinas" class="row gy-4">
        <p class="text-muted">Carregando...</p>
      </div>
    </section>

    <!-- Cards Feminino -->
    <section id="feminino" class="mb-5">
      <h2 class="mb-1">Feminino</h2>
      <p class="text-muted mb-3">Lojas de moda feminina em Belo Horizonte.</p>
      <div id="lojas-femininas" class="row gy-4">
        <p class="text-muted">Carregando...</p>
      </div>
    </section>

    <!-- Sobre o responsável -->
    <section id="responsavel" class="sobre-responsavel p-4 bg-light rounded shadow-sm mb-5">
      <h2>Sobre o responsável pelo site</h2>
      <ul>
        <li><strong>Nome:</strong> Enzo Rodrigues Lana</li>
        <li><strong>Curso:</strong> Engenharia de Software</li>
        <li><strong>Objetivo do site:</strong> Mostrar a localização das lojas de roupa mais populares de Belo Horizonte em um só site.</li>
        <li><strong>Responsividade:</strong> Versão mobile com navegação simples e layout adaptável.</li>
      </ul>
    </section>

  </main>

  <footer class="text-center py-4 bg-dark text-white">
    <p>&copy; 2024 BH Shopping Guide. Todos os direitos reservados.</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="script.js"></script>
</body>
</html>


